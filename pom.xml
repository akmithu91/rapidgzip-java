<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.rapidgzip</groupId>
    <artifactId>rapidgzip-java</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>rapidgzip-java</name>
    <description>
        Parallel gzip decompression for Java via FFM.
        Wraps rapidgzip C++ with ISA-L, zlib-ng, rpmalloc.
        Linux x86_64 only. Single self-contained JAR.
    </description>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>

        <!-- rapidgzip git repo URL and branch/tag to clone -->
        <rapidgzip.repo>https://github.com/mxmlnkn/rapidgzip.git</rapidgzip.repo>
        <rapidgzip.tag>main</rapidgzip.tag>

        <!-- Where the clone lands (inside target/, wiped by mvn clean) -->
        <rapidgzip.clone.dir>${project.build.directory}/rapidgzip-src</rapidgzip.clone.dir>

        <!-- The librapidarchive root inside the clone -->
        <rapidgzip.root>${rapidgzip.clone.dir}/librapidarchive</rapidgzip.root>

        <!-- Native build artifacts -->
        <native.build.dir>${project.basedir}/native/build</native.build.dir>
        <native.resource.dir>${project.basedir}/src/main/resources/native/linux-x86_64</native.resource.dir>
    </properties>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
            </resource>
        </resources>

        <plugins>

            <!--
              PHASE: initialize
              Create all directories needed by later phases.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <id>create-dirs</id>
                        <phase>initialize</phase>
                        <goals><goal>run</goal></goals>
                        <configuration>
                            <target>
                                <mkdir dir="${project.build.directory}"/>
                                <mkdir dir="${native.build.dir}"/>
                                <mkdir dir="${native.resource.dir}"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.1.0</version>
                <executions>

                    <!--
                      PHASE: initialize
                      Clone rapidgzip with all submodules (skipped if already present).
                      The clone goes into target/rapidgzip-src so mvn clean removes it.
                      To force a fresh clone: mvn clean package
                      To pin a version: mvn package -Drapidgzip.tag=v0.14.3
                    -->
                    <execution>
                        <id>git-clone-rapidgzip</id>
                        <phase>initialize</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>bash</executable>
                            <arguments>
                                <argument>-c</argument>
                                <argument>
if [ -d "${rapidgzip.clone.dir}/librapidarchive/src" ]; then
    echo "[rapidgzip-java] rapidgzip source already present, skipping clone"
else
    echo "[rapidgzip-java] Cloning rapidgzip (${rapidgzip.tag}) with submodules..."
    rm -rf "${rapidgzip.clone.dir}"
    git clone --recursive --depth 1 --branch "${rapidgzip.tag}" \
        "${rapidgzip.repo}" "${rapidgzip.clone.dir}"
    echo "[rapidgzip-java] Clone complete"
fi
                                </argument>
                            </arguments>
                        </configuration>
                    </execution>

                    <!--
                      PHASE: generate-resources
                      cmake configure
                    -->
                    <execution>
                        <id>cmake-configure</id>
                        <phase>generate-resources</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>cmake</executable>
                            <workingDirectory>${native.build.dir}</workingDirectory>
                            <arguments>
                                <argument>${project.basedir}/native</argument>
                                <argument>-DCMAKE_BUILD_TYPE=Release</argument>
                                <argument>-DRAPIDGZIP_ROOT=${rapidgzip.root}</argument>
                            </arguments>
                        </configuration>
                    </execution>

                    <!--
                      PHASE: generate-resources
                      cmake build (parallel)
                    -->
                    <execution>
                        <id>cmake-build</id>
                        <phase>generate-resources</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>cmake</executable>
                            <workingDirectory>${native.build.dir}</workingDirectory>
                            <arguments>
                                <argument>--build</argument>
                                <argument>.</argument>
                                <argument>--target</argument>
                                <argument>rapidgzip_ffi</argument>
                                <argument>--parallel</argument>
                            </arguments>
                        </configuration>
                    </execution>

                    <!--
                      PHASE: generate-resources
                      Copy the .so into JAR resources
                    -->
                    <execution>
                        <id>copy-native-lib</id>
                        <phase>generate-resources</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>cp</executable>
                            <arguments>
                                <argument>${native.build.dir}/librapidgzip_ffi.so.1</argument>
                                <argument>${native.resource.dir}/librapidgzip_ffi.so</argument>
                            </arguments>
                        </configuration>
                    </execution>

                </executions>
            </plugin>

            <!--
              PHASE: compile
              javac with enable-preview for FFM on JDK 21
              (drop enable-preview on JDK 22+)
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>25</source>
                    <target>25</target>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- PHASE: package -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.3.0</version>
            </plugin>

            <!-- mvn clean: also wipe native/build and staged .so -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-clean-plugin</artifactId>
                <version>3.3.2</version>
                <configuration>
                    <filesets>
                        <fileset>
                            <directory>${native.build.dir}</directory>
                        </fileset>
                        <fileset>
                            <directory>src/main/resources/native</directory>
                        </fileset>
                    </filesets>
                </configuration>
            </plugin>

        </plugins>
    </build>

    <!--
      Profile: skip the native build entirely (clone + cmake).
      Useful when you already have the .so in src/main/resources.
      Usage:  mvn package -Dskip.native
    -->
    <profiles>
        <profile>
            <id>skip-native</id>
            <activation>
                <property>
                    <name>skip.native</name>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <executions>
                            <execution><id>git-clone-rapidgzip</id><phase>none</phase></execution>
                            <execution><id>cmake-configure</id><phase>none</phase></execution>
                            <execution><id>cmake-build</id><phase>none</phase></execution>
                            <execution><id>copy-native-lib</id><phase>none</phase></execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

</project>
